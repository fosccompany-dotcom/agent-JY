# Railway Variables 에 넣을 값 (실제 값은 절대 커밋 금지)
TELEGRAM_BOT_TOKEN=BotFather_토큰        # 기존 봇과 같은 토큰
ALLOWED_CHAT_ID=본인_chat_id             # /id 로 확인 후 입력
GIT_REPO_URL=https://github.com/fosccompany-dotcom/Agent-vivian.git
GITHUB_TOKEN=repo권한_PAT
REPO_DIR=/app/work/Agent-vivian/vivian_repo

# ── 뇌(자연어 대화) 켜기 — env 두 줄이면 끝, 코드 안 건드림 ──
CHAT_ENABLED=true                        # 끄려면 false
ANTHROPIC_API_KEY=회사_Console_API키      # 회사 계정 키
ANTHROPIC_MODEL=claude-sonnet-4-6        # 균형(중간). 바꾸려면 이 값만 교체
